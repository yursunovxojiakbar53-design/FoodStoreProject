# Example application properties (do NOT commit real secrets)
spring.application.name=FoodStore
spring.datasource.url=jdbc:postgresql://localhost:5432/foodstore
# Replace these with your local DB credentials or set environment variables DB_USERNAME and DB_PASSWORD
spring.datasource.username=postgres
spring.datasource.password=changeme
spring.jpa.hibernate.ddl-auto=update
server.port=8080
file.upload-dir=uploads
app.cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:3000}

# Email (Gmail SMTP)
app.mail.fallback-username=your-email@example.com
app.mail.fallback-password=your-app-password
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=${MAIL_USERNAME:${app.mail.fallback-username}}
spring.mail.password=${MAIL_PASSWORD:${app.mail.fallback-password}}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
spring.mail.properties.mail.smtp.connectiontimeout=5000
spring.mail.properties.mail.smtp.timeout=5000
spring.mail.properties.mail.smtp.writetimeout=5000
spring.mail.default-encoding=UTF-8

# Telegram Bot
telegram.bot.token=${TELEGRAM_BOT_TOKEN:}
telegram.bot.username=${TELEGRAM_BOT_USERNAME:}
telegram.bot.enabled=${TELEGRAM_BOT_ENABLED:false}
telegram.bot.admin-chat-ids=${TELEGRAM_ADMIN_CHAT_IDS:}
telegram.bot.page-size=5
telegram.bot.backend-base-url=${TELEGRAM_BACKEND_BASE_URL:http://localhost:8080}

# Instructions:
# 1) Copy this file to src/main/resources/application.properties and fill values for local development.
# 2) For production, prefer setting DB_PASSWORD and MAIL_PASSWORD via environment variables and keep application.properties out of version control.
